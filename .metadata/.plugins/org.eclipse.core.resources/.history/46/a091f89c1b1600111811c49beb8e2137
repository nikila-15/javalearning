package edu.cca.niki.oms.service;

import java.util.List;

import edu.cca.niki.oms.models.Product;
import edu.cca.niki.oms.repository.ProductRepository;

public class ProductService {
   private ProductRepository repository=null;
   public ProductService() {
	   repository=new ProductRepository();
   }
   public void readAllProducts()
   {    
	   List<Product>products=repository.readAll();
	   System.out.printf("%-10s%-20s%-20s\n","Id","name","Price");
		for(int i=0;i<products.size();i++)
		{
			System.out.println(products.get(i));
		}
   }
}
